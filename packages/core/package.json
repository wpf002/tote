{
  "name": "@tote/core",
  "version": "0.0.0",
  "private": true,
  "description": "Money layer, ownership resolver, and immutable posting engine — the financial spine of Tote.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
